---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubButton from '../components/GitHubButton.astro';
import { people } from '../data/site';
---

<BaseLayout
  title="Galaxio Team - Team"
  description="A small product-focused team building performance testing tooling."
>
  <section class="hero">
    <span class="eyebrow">Team</span>
    <h1 class="display">People who turn tooling into something usable.</h1>
    <p class="lede">
      Galaxio Team is intentionally small and product-focused. We keep the
      work close to real users, and we like each role to have a clear lane.
    </p>
    <div class="actions">
      <GitHubButton />
      <a class="button secondary" href="/community">Community</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <span class="eyebrow">Core team</span>
        <h2>Small team, clear responsibilities.</h2>
      </div>
      <p>
        This page is designed to show people, not just repositories. Add names,
        photos, and bios here as the team grows.
      </p>
    </div>

    <div class="people-grid">
      {people.map((person) => (
        <article class="person">
          <div class={`avatar ${person.accent}`}>{person.initials}</div>
          <span class="role">{person.role}</span>
          <strong>{person.name}</strong>
          <p>{person.bio}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <span class="eyebrow">How we work</span>
        <h2>Practical, focused, and close to the stack.</h2>
      </div>
    </div>

    <div class="grid-2">
      <article class="card">
        <strong>Build with real users in mind</strong>
        <p>We prefer useful tooling over broad claims and abstract platform language.</p>
      </article>
      <article class="card">
        <strong>Keep the surface area small</strong>
        <p>We aim for a limited number of well-maintained products rather than a large sprawl.</p>
      </article>
      <article class="card">
        <strong>Make contribution easy</strong>
        <p>Documentation, issues, and integrations should be straightforward to follow.</p>
      </article>
      <article class="card">
        <strong>Prioritize urgent work when needed</strong>
        <p>For important features, we can fast-track delivery as a paid engagement.</p>
      </article>
    </div>
  </section>
</BaseLayout>
